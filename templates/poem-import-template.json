    {
      "id": "wang-lu-shan-pu-bu",
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        "日照香炉生紫烟",
        "遥看瀑布挂前川",
        "飞流直下三千尺",
        "疑是银河落九天"
      ],
      "theme": "山水",
      "mood": "壮阔、明亮",
      "imagery": ["香炉峰", "瀑布", "银河"],
